From 9ccb79dbd2517419a15ae90889311fa17df989ec Mon Sep 17 00:00:00 2001
From: zhouzilong <zhouzilong@uniontech.com>
Date: Fri, 6 Mar 2026 17:42:31 +0800
Subject: [PATCH] implement USEC with libusec.so

---
 configure.ac | 15 +++++++++++++++
 src/copy.c   | 10 ++++++++--
 src/local.mk |  3 +++
 3 files changed, 26 insertions(+), 2 deletions(-)

diff --git a/configure.ac b/configure.ac
index 8c3fe09..6d9d266 100644
--- a/configure.ac
+++ b/configure.ac
@@ -129,6 +129,21 @@ AC_ARG_ENABLE([bold-man-page-references],
 )
 AM_CONDITIONAL([BOLD_MAN_REFS], [test "$gl_bold_manpages" != no])
 
+AC_ARG_WITH([usec],
+  [AS_HELP_STRING([--with-usec], [enable usec library support (for UOS system auditing)])],
+  [with_usec=$withval],
+  [with_usec=auto])
+
+if test "x$with_usec" != "xno"; then
+  AC_CHECK_LIB([usec], [usec_get_file_audit_status],
+               [LIB_USEC=-lusec
+                AC_DEFINE([HAVE_USEC], [1], [Define to 1 if you have the usec library])],
+               [if test "x$with_usec" != "xauto"; then
+                  AC_MSG_ERROR([usec library requested but not found])
+                fi])
+fi
+AC_SUBST([LIB_USEC])
+
 AC_ARG_ENABLE([gcc-warnings],
   [AS_HELP_STRING([--enable-gcc-warnings@<:@=TYPE@:>@],
     [control generation of GCC warnings.  The TYPE 'no' disables
diff --git a/src/copy.c b/src/copy.c
index f834556..d272908 100644
--- a/src/copy.c
+++ b/src/copy.c
@@ -33,6 +33,10 @@
 # include <priv.h>
 #endif
 
+#ifdef HAVE_USEC
+#include <usec/usec.h>
+#endif
+
 #include "system.h"
 #include "acl.h"
 #include "alignalloc.h"
@@ -1626,7 +1630,8 @@ copy_reg (char const *src_name, char const *dst_name,
 
         char src_name_abs[PATH_MAX] = {0};
         realpath(src_name, src_name_abs);//源文件
-        if (get_file_audit_status(src_name_abs) == 0)
+#ifdef HAVE_USEC
+        if (usec_get_file_audit_status(src_name_abs) == 0)
         {
           char dst_name_abs[PATH_MAX] = {0};
           char hostname[256]={0};
@@ -1662,9 +1667,10 @@ copy_reg (char const *src_name, char const *dst_name,
           if(magic)
             magic_close(magic);
 
-          write_audit_log(msg);
+          usec_write_audit_log(msg);
           free(msg);
         }
+#endif
     }
 
   if (x->preserve_timestamps)
diff --git a/src/local.mk b/src/local.mk
index f45b911..4c74391 100644
--- a/src/local.mk
+++ b/src/local.mk
@@ -296,6 +296,9 @@ src_ls_LDADD += $(FILE_HAS_ACL_LIB)
 # for various xattr functions
 copy_ldadd += $(LIB_XATTR)
 
+# for usec auditing
+copy_ldadd += $(LIB_USEC)
+
 # for print_unicode_char
 src_printf_LDADD += $(LIBICONV)
 
-- 
2.20.1

